<mvc:View
  controllerName="com.locationtracker.locationtracker.controller.App"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  displayBlock="true">
  <Page title="Fleet Tracker">
    <content>
      <VBox class="trackerPage">
        <HBox class="toolbarRow" wrap="Wrap" justifyContent="SpaceBetween" alignItems="Center">
          <VBox>
            <Title text="{= ${view>/isAdmin} ? 'Admin Dashboard' : 'Driver Tracker'}" level="H2" />
            <Text text="{= ${view>/user/email} ? 'Signed in as ' + ${view>/user/email} : 'Loading signed-in user'}" />
            <Text text="{view>/statusText}" />
            <Text text="{view>/permissionText}" />
          </VBox>
          <HBox wrap="Wrap" class="buttonCluster">
            <Button text="Start Trip" type="Emphasized" press=".onStartTracking" visible="{= ${view>/isDriver} &amp;&amp; !${view>/tracking} }" />
            <Button text="Stop Trip" type="Reject" press=".onStopTracking" visible="{= ${view>/isDriver} &amp;&amp; ${view>/tracking} }" />
            <Button text="Refresh Path" press=".onRefreshPath" visible="{view>/isDriver}" />
            <Button text="View Trips" icon="sap-icon://list" press=".onNavigateToTrips" />
          </HBox>
        </HBox>

        <Panel headerText="Assign Driver" class="adminPanel" visible="{view>/isAdmin}">
          <content>
            <VBox class="adminForm">
              <Input value="{view>/driverDraft/name}" placeholder="Driver name" />
              <Input value="{view>/driverDraft/email}" placeholder="Driver login email" type="Email" />
              <Input value="{view>/driverDraft/phone}" placeholder="Phone number" />
              <Button text="Create Driver" type="Emphasized" press=".onCreateDriver" />
            </VBox>
          </content>
        </Panel>

        <HBox wrap="Wrap" class="cardRow" visible="{view>/isDriver}">
          <Panel headerText="Current Trip" class="metricCard">
            <content>
              <VBox class="metricContent">
                <ObjectStatus title="Title" text="{= ${view>/currentTrip/title} || 'No active trip'}" />
                <ObjectStatus title="Status" text="{= ${view>/currentTrip/status} || 'IDLE'}" />
                <ObjectStatus title="Started" text="{= ${view>/currentTrip/startedAt} || '-'}" />
              </VBox>
            </content>
          </Panel>

          <Panel headerText="Live Position" class="metricCard">
            <content>
              <VBox class="metricContent">
                <ObjectStatus title="Latitude" text="{= ${view>/lastPoint/latitude} || '-'}" />
                <ObjectStatus title="Longitude" text="{= ${view>/lastPoint/longitude} || '-'}" />
                <ObjectStatus title="Accuracy (m)" text="{= ${view>/lastPoint/accuracy} || '-'}" />
              </VBox>
            </content>
          </Panel>

          <Panel headerText="Captured Points" class="metricCard">
            <content>
              <VBox class="metricContent">
                <ObjectNumber number="{view>/totalPoints}" unit="pts" />
              </VBox>
            </content>
          </Panel>
        </HBox>

        <VBox class="mapShell" visible="{view>/isDriver}">
          <core:HTML content='&lt;div id="tracker-map" class="trackerMap"&gt;&lt;/div&gt;' />
        </VBox>
      </VBox>
    </content>
  </Page>
</mvc:View>
