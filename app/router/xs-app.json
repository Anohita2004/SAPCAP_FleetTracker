{
  "welcomeFile": "/com.locationtracker.locationtracker/index.html",
  "authenticationMethod": "route",
  "routes": [
    {
      "source": "^/tracker/(.*)$",
      "target": "/tracker/$1",
      "destination": "srv-api",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    },
    {
      "source": "^/tracker$",
      "target": "/tracker",
      "destination": "srv-api",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    },
    {
      "source": "^/(.*)$",
      "localDir": "resources",
      "authenticationType": "xsuaa"
    }
  ]
}
