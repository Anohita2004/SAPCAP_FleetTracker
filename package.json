{
  "name": "location-tracker",
  "version": "1.0.0",
  "private": true,
  "description": "CAP full stack location tracker with SAPUI5 frontend and SAP HANA persistence",

  "scripts": {
    "start": "cds serve",
    "dev": "cds watch",
    "hybrid": "cds watch --profile hybrid",
    "build": "cds build",
    "deploy": "cds deploy --to hana"
  },

  "dependencies": {
    "@sap/cds": "^8",
    "@cap-js/hana": "^1.9.2",
    "express": "^4"
  },

  "devDependencies": {
    "@sap/cds-dk": "^8",
    "@cap-js/sqlite": "^1",
    "cds-plugin-ui5": "^0.13.0"
  },

  "cds": {
    "folders": {
      "db": "db",
      "srv": "srv",
      "app": "app"
    },

    "requires": {
      "db": {
        "kind": "sqlite",

        "[hybrid]": {
          "kind": "hana",
          "impl": "@cap-js/hana",
          "deploy-format": "hdbtable"
        },

        "[production]": {
          "kind": "hana",
          "impl": "@cap-js/hana",
          "deploy-format": "hdbtable"
        }
      }
    }
  },

  "workspaces": [
    "app/*"
  ]
}